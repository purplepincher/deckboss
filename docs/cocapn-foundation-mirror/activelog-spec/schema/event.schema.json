{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://activelog.ai/schema/v1/envelope.schema.json",
  "title": "ActiveLog v1 event envelope",
  "type": "object",
  "required": ["alv", "dev", "seq", "ts", "mono", "type", "body"],
  "additionalProperties": false,
  "properties": {
    "alv": { "const": 1, "description": "spec version" },
    "dev": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$",
      "description": "stable device id; (dev,seq) is the global unique key"
    },
    "seq": { "type": "integer", "minimum": 0, "description": "per-device monotonic counter" },
    "ts": { "type": "integer", "description": "UTC epoch ms, GPS-disciplined when available" },
    "mono": { "type": "integer", "minimum": 0, "description": "device monotonic clock ms" },
    "type": {
      "type": "string",
      "pattern": "^[a-z]+\\.[a-z_]+$",
      "description": "namespaced event type, e.g. speech.segment"
    },
    "fix": {
      "type": "object",
      "required": ["lat", "lon"],
      "additionalProperties": false,
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 },
        "sog": { "type": "number", "description": "speed over ground, kn" },
        "cog": { "type": "number", "minimum": 0, "maximum": 360 },
        "hdop": { "type": "number" }
      }
    },
    "prev": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "optional per-device hash chain: sha256 of this device's previous event line"
    },
    "body": { "type": "object", "description": "type-specific payload; unknown types MUST be preserved" }
  }
}
