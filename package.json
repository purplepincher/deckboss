{
  "name": "deckboss",
  "version": "0.1.0",
  "description": "Voice-first digital fishing logbook. Local-first, your storage, your data.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
